# ── ODIN Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ── AI / LLM ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# ── Geospatial / Maps ─────────────────────────────────────────────
MAPBOX_TOKEN=your_mapbox_public_token_here

# ── Weather Data (optional — synthetic fallback used if missing) ──
OPENWEATHER_API_KEY=your_openweather_key_here
NOAA_API_KEY=your_noaa_api_key_here

# ── PostgreSQL + PostGIS ──────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=odin
POSTGRES_USER=odin_user
POSTGRES_PASSWORD=odin_password

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=odin_neo4j_password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App Settings ──────────────────────────────────────────────────
ODIN_ENV=development
ODIN_LOG_DIR=./logs
ODIN_DEBUG=true
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Feature Flags ────────────────────────────────────────────────
USE_SYNTHETIC_WEATHER=true
USE_SYNTHETIC_GRID=false
FORCE_WEATHER_API_FAILURE=false
